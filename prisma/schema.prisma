// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum WorkspacePlan {
  FREE
  PRO
  BUSINESS
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  DOING
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum OtpType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum AuditLogSeverity {
  INFO
  WARN
  CRITICAL
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT_ADDED
  INVITATION_RECEIVED
}

enum OAuthProvider {
  GOOGLE
}

enum UserTheme {
  LIGHT
  DARK
  SYSTEM
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id           String @id @default(uuid())
  email        String @unique @db.VarChar(255)
  username     String @unique @db.VarChar(100)
  displayName  String @db.VarChar(100)
  passwordHash String @db.Text

  avatarUrl     String?  @db.VarChar(500)
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  isSuspended   Boolean? @default(false)

  role UserRole @default(USER) // Roles: USER, ADMIN, SUPER_ADMIN

  lastLoginAt        DateTime?
  lastLoginIp        String?   @db.VarChar(45)
  failedLoginAttempt Int       @default(0)
  passwordChangedAt  DateTime?
  twoFactorEnabled   Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  ownedWorkspaces Workspace[]

  sessions                Session[]
  otpCodes                OtpCode[]
  auditLogs               AuditLog[]        @relation("ActorLogs")
  notifications           Notification[]
  oauthAccounts           OAuthAccount[]
  loginHistories          LoginHistory[]
  userSettings            UserSettings?
  workspaceMembers        WorkspaceMember[]
  receivedInvitations     Invitation[]
  invitedWorkspaceMembers WorkspaceMember[] @relation("WorkspaceMemberInviter")

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

model Workspace {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(255)
  ownerId     String?
  logoUrl     String?       @db.VarChar(500)
  description String?       @db.Text
  plan        WorkspacePlan @default(FREE)
  isActive    Boolean       @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  owner         User?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members       WorkspaceMember[]
  settings      WorkspaceSettings?
  tasks         Task[]
  notifications Notification[]
  auditLogs     AuditLog[]
  attachments   Attachment[]
  invitations   Invitation[]

  @@index([name])
  @@index([ownerId])
}

model WorkspaceSettings {
  id                  String  @id @default(uuid())
  workspaceId         String  @unique
  allowMemberInvites  Boolean @default(false)
  require2fa          Boolean @default(false)
  allowedEmailDomains Json?   @db.JsonB // Array of strings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model WorkspaceMember {
  id              String              @id @default(uuid())
  workspaceId     String
  userId          String
  role            WorkspaceMemberRole @default(MEMBER)
  joinedAt        DateTime            @default(now())
  invitedByUserId String?
  isActive        Boolean             @default(true)
  lastAccessedAt  DateTime?

  // Relations
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviter             User?         @relation("WorkspaceMemberInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  taskComments        TaskComment[]
  sentInvitations     Invitation[]  @relation("InvitedByMember")
  assignedTasks       Task[]        @relation("AssignedToMember")
  createdTasks        Task[]        @relation("CreatedByMember")
  uploadedAttachments Attachment[]  @relation("UploadedByMember")

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Task {
  id          String       @id @default(uuid())
  workspaceId String
  title       String       @db.VarChar(255)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)

  assignedToMemberId String?
  createdByMemberId  String
  dueDate            DateTime?
  completedAt        DateTime?
  archived           Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  comments         TaskComment[]
  attachments      Attachment[]
  assignedToMember WorkspaceMember? @relation("AssignedToMember", fields: [assignedToMemberId], references: [id])
  createdByMember  WorkspaceMember  @relation("CreatedByMember", fields: [createdByMemberId], references: [id])

  @@index([workspaceId])
  @@index([title])
  @@index([status])
  @@index([priority])
  @@index([assignedToMemberId])
  @@index([createdByMemberId])
}

model TaskComment {
  id                String  @id @default(uuid())
  taskId            String
  workspaceMemberId String?
  content           String  @db.Text
  edited            Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  task            Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workspaceMember WorkspaceMember? @relation(fields: [workspaceMemberId], references: [id])

  @@index([taskId])
  @@index([workspaceMemberId])
}

model Invitation {
  id          String @id @default(uuid())
  workspaceId String

  email     String              @db.VarChar(255)
  role      WorkspaceMemberRole @default(MEMBER)
  tokenHash String              @db.VarChar(255)
  invitedBy String

  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender    WorkspaceMember @relation("InvitedByMember", fields: [invitedBy], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id])
  userId    String?

  @@index([email])
  @@index([workspaceId])
}

model Session {
  id     String @id @default(uuid())
  userId String

  deviceName      String? @db.VarChar(255)
  browser         String? @db.VarChar(100)
  operatingSystem String? @db.VarChar(100)
  ipAddress       String  @db.VarChar(45)
  country         String? @db.VarChar(100)
  city            String? @db.VarChar(100)
  userAgent       String? @db.Text

  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id     String @id @default(uuid())
  userId String

  email    String  @db.VarChar(255)
  codeHash String  @db.VarChar(255)
  type     OtpType

  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
}

/// Append-only audit logs - should never allow update or delete
model AuditLog {
  id          String  @id @default(uuid())
  workspaceId String?

  actorId   String
  metadata  Json?            @db.JsonB
  ipAddress String?          @db.VarChar(45)
  userAgent String?          @db.Text
  severity  AuditLogSeverity @default(INFO)

  createdAt DateTime @default(now())

  // Relations
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor     User       @relation("ActorLogs", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([workspaceId])
  @@index([actorId])
}

model Notification {
  id     String @id @default(uuid())
  userId String

  workspaceId String?
  title       String           @db.VarChar(255)
  message     String           @db.Text
  type        NotificationType

  readAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
}

model OAuthAccount {
  id     String @id @default(uuid())
  userId String

  provider          OAuthProvider
  providerAccountId String        @db.VarChar(255)
  accessToken       String        @db.Text
  refreshToken      String?       @db.Text

  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model LoginHistory {
  id     String  @id @default(uuid())
  userId String?

  email         String   @db.VarChar(255)
  success       Boolean
  failureReason String?  @db.VarChar(255)
  ipAddress     String   @db.VarChar(45)
  userAgent     String?  @db.Text
  country       String?  @db.VarChar(100)
  createdAt     DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique

  theme                 UserTheme @default(SYSTEM)
  emailNotifications    Boolean   @default(true)
  securityNotifications Boolean   @default(true)
  timezone              String    @default("UTC") @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Attachment {
  id          String @id @default(uuid())
  workspaceId String

  uploadedBy String?
  taskId     String?
  fileName   String  @db.VarChar(255)
  mimeType   String  @db.VarChar(100)
  fileSize   BigInt
  storageKey String  @db.VarChar(500)

  createdAt DateTime @default(now())

  // Relations
  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  WorkspaceMember? @relation("UploadedByMember", fields: [uploadedBy], references: [id], onDelete: SetNull)
  task      Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([uploadedBy])
  @@index([taskId])
}
